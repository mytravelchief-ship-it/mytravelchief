{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "find node_modules -name esbuild -type f -path '*/bin/*' -exec chmod +x {} + 2>/dev/null; vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "include": [
      "/",
      "/tariff",
      "/tariff?vehicle=dzire",
      "/tariff?vehicle=ertiga",
      "/tariff?vehicle=innova",
      "/tariff?vehicle=crysta",
      "/tariff?vehicle=tempo",
      "/tariff?vehicle=luxury-tempo",
      "/tariff?vehicle=urbania",
      "/tariff?vehicle=coach-35",
      "/tariff?vehicle=coach-45",
      "/tariff?vehicle=bus-49"
    ],
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "skipThirdPartyRequests": true,
    "inlineCss": true
  },
  "pnpm": {
    "onlyBuiltDependencies": ["puppeteer", "esbuild", "better-sqlite3"]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
